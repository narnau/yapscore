# OpenRouter API key — get one at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# Model to use — any model available on OpenRouter
# See full list at https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# Optional: full path to mscore if not on PATH
# MSCORE_PATH=/Applications/MuseScore 4.app/Contents/MacOS/mscore

# Supabase — accepts both new format (sb_publishable_* / sb_secret_*) and legacy JWT format
# Local: get them from `supabase status -o json` (ANON_KEY and SERVICE_ROLE_KEY fields)
# Production: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_PRICE_ID=price_your_price_id_here

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry — API token for scripts/fix-sentry-errors.sh
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
# Scopes: project:read, event:read, event:admin
SENTRY_API_TOKEN=sntryu_your_token_here

# Sentry — Build plugin token for source map uploads (used by next.config.ts)
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
# Scopes: project:releases, org:read
# Also stored in .env.sentry-build-plugin (that file is loaded automatically)
SENTRY_AUTH_TOKEN=sntrys_your_token_here
