# OpenRouter API key — get one at https://openrouter.ai
OPENROUTER_API_KEY=

# Model to use — any model available on OpenRouter
# See full list at https://openrouter.ai/models
OPENROUTER_MODEL=

# Supabase — local dev (http://127.0.0.1:54323 for Studio)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_EUR=
STRIPE_PRICE_ID_USD=
STRIPE_PRICE_ID_GBP=

NEXT_PUBLIC_APP_URL=

# Sentry — API token for reading/resolving issues (used by scripts/fix-sentry-errors.sh)
SENTRY_API_TOKEN=

# PostHog — product analytics (EU region)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=